generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  INSTITUTION_ADMIN
  INSTRUCTOR
  STUDENT
  GUARDIAN
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LessonType {
  VIDEO
  QUIZ
  DOCUMENT
  LIVE
}

enum IntegrationType {
  SCORM
  LTI
  GOOGLE_CLASSROOM
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  TRIALING
}

enum NotificationType {
  WELCOME
  ASSIGNMENT_POSTED
  ASSIGNMENT_GRADED
  LIVE_CLASS_REMINDER
  CERTIFICATE_ISSUED
  LOW_ATTENDANCE
  PAYMENT_FAILED
  SUBSCRIPTION_EXPIRING
  GENERAL
}

model Institution {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  plan      String   @default("free")
  logoUrl   String?
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  courses       Course[]
  integrations  Integration[]
  subscriptions Subscription[]
}

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  image         String?
  role          UserRole  @default(STUDENT)
  institutionId String?
  avatarUrl     String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  institution      Institution?     @relation(fields: [institutionId], references: [id])
  accounts         Account[]
  sessions         Session[]
  coursesTeaching  Course[]         @relation("InstructorCourses")
  enrollments      Enrollment[]
  quizAttempts     QuizAttempt[]
  submissions      Submission[]
  attendances      Attendance[]
  certificates     Certificate[]
  discussions      Discussion[]
  notifications    Notification[]
  guardianLinks    GuardianLink[]   @relation("Guardian")
  studentLinks     GuardianLink[]   @relation("Student")

  @@index([institutionId])
  @@index([email])
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model GuardianLink {
  id         String @id @default(uuid())
  guardianId String
  studentId  String

  guardian User @relation("Guardian", fields: [guardianId], references: [id], onDelete: Cascade)
  student  User @relation("Student", fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([guardianId, studentId])
}

model Course {
  id               String       @id @default(uuid())
  title            String
  description      String?
  institutionId    String
  instructorId     String
  status           CourseStatus @default(DRAFT)
  thumbnailUrl     String?
  isPublic         Boolean      @default(false)
  scormPackageUrl  String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  institution   Institution    @relation(fields: [institutionId], references: [id])
  instructor    User           @relation("InstructorCourses", fields: [instructorId], references: [id])
  sections      CourseSection[]
  enrollments   Enrollment[]
  assignments   Assignment[]
  liveClasses   LiveClass[]
  discussions   Discussion[]

  @@index([institutionId])
  @@index([instructorId])
}

model CourseSection {
  id       String @id @default(uuid())
  courseId String
  title    String
  order    Int    @default(0)

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId])
}

model Lesson {
  id         String     @id @default(uuid())
  sectionId  String
  title      String
  type       LessonType @default(VIDEO)
  muxAssetId String?
  content    String?
  order      Int        @default(0)
  duration   Int?

  section     CourseSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  quiz        Quiz?
  discussions Discussion[]

  @@index([sectionId])
}

model Enrollment {
  id            String    @id @default(uuid())
  studentId     String
  courseId      String
  progress      Float     @default(0)
  completedAt   DateTime?
  certificateId String?   @unique
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  student     User         @relation(fields: [studentId], references: [id])
  course      Course       @relation(fields: [courseId], references: [id])
  certificate Certificate?

  @@unique([studentId, courseId])
  @@index([courseId])
}

model Quiz {
  id        String @id @default(uuid())
  lessonId  String @unique
  questions Json
  passMark  Int    @default(70)

  lesson   Lesson        @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  attempts QuizAttempt[]
}

model QuizAttempt {
  id          String   @id @default(uuid())
  quizId      String
  studentId   String
  score       Float
  answers     Json
  completedAt DateTime @default(now())

  quiz    Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student User @relation(fields: [studentId], references: [id])

  @@index([quizId, studentId])
}

model Assignment {
  id          String   @id @default(uuid())
  courseId    String
  title       String
  description String?
  dueDate     DateTime?
  maxScore    Int      @default(100)
  createdAt   DateTime @default(now())

  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  submissions Submission[]

  @@index([courseId])
}

model Submission {
  id           String    @id @default(uuid())
  assignmentId String
  studentId    String
  fileUrl      String?
  grade        Float?
  feedback     String?
  submittedAt  DateTime  @default(now())

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    User       @relation(fields: [studentId], references: [id])

  @@unique([assignmentId, studentId])
}

model LiveClass {
  id           String   @id @default(uuid())
  courseId     String
  title        String
  scheduledAt  DateTime
  duration     Int      @default(60)
  meetingUrl   String?
  recordingUrl String?
  createdAt    DateTime @default(now())

  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  attendances Attendance[]

  @@index([courseId])
}

model Attendance {
  id          String    @id @default(uuid())
  liveClassId String?
  courseId    String?
  studentId   String
  joinedAt    DateTime?
  leftAt      DateTime?
  duration    Int?
  isPresent   Boolean   @default(false)
  markedAt    DateTime  @default(now())

  liveClass LiveClass? @relation(fields: [liveClassId], references: [id], onDelete: Cascade)
  student   User       @relation(fields: [studentId], references: [id])

  @@index([studentId])
  @@index([liveClassId])
}

model Certificate {
  id           String   @id @default(uuid())
  enrollmentId String   @unique
  studentId    String
  courseId     String
  issuedAt     DateTime @default(now())
  verifyCode   String   @unique @default(uuid())

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id])
  student    User       @relation(fields: [studentId], references: [id])
}

model Discussion {
  id        String   @id @default(uuid())
  courseId  String
  lessonId  String?
  userId    String
  body      String
  parentId  String?
  createdAt DateTime @default(now())

  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson  Lesson? @relation(fields: [lessonId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  parent  Discussion?  @relation("Thread", fields: [parentId], references: [id])
  replies Discussion[] @relation("Thread")

  @@index([courseId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType @default(GENERAL)
  payload   Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model Integration {
  id            String          @id @default(uuid())
  institutionId String
  type          IntegrationType
  config        Json?
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())

  institution Institution @relation(fields: [institutionId], references: [id])

  @@index([institutionId])
}

model Plan {
  id          String  @id @default(uuid())
  name        String
  slug        String  @unique
  price       Float   @default(0)
  currency    String  @default("USD")
  features    Json?
  maxStudents Int     @default(50)
  maxCourses  Int     @default(3)
  maxStorage  Int     @default(2048)

  subscriptions Subscription[]
}

model Subscription {
  id                String             @id @default(uuid())
  institutionId     String
  planId            String
  status            SubscriptionStatus @default(TRIALING)
  currentPeriodEnd  DateTime?
  paymentProvider   String?
  externalId        String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  institution Institution @relation(fields: [institutionId], references: [id])
  plan        Plan        @relation(fields: [planId], references: [id])

  @@index([institutionId])
}
