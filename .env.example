# ═══════════════════════════════════════════════════════════════════
#  OYO-Elearner — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to GitHub.
# ═══════════════════════════════════════════════════════════════════

# ── Database (Required) ───────────────────────────────────────────
# Local dev: use SQLite → DATABASE_URL="file:./prisma/dev.db"
# Production (Neon): get connection string from neon.tech
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── NextAuth (Required) ───────────────────────────────────────────
# Generate secret: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
# Local dev: http://localhost:3000
# Production: your Vercel URL e.g. https://oyo-elearn.vercel.app
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Google OAuth (Optional — enables "Continue with Google") ──────
# Get from: console.cloud.google.com → Credentials → OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Mux Video (Optional — enables video lectures) ─────────────────
# Get from: dashboard.mux.com → Settings → API Access Tokens
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# ── Cloudinary (Optional — enables file/image uploads) ────────────
# Get from: cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── OpenAI (Optional — enables AI tutor & quiz generator) ─────────
# Get from: platform.openai.com → API Keys
OPENAI_API_KEY=

# ── Paystack (Optional — enables NGN/GHS/KES billing) ────────────
# Get from: dashboard.paystack.com → Settings → API Keys
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# ── Stripe (Optional — enables USD/EUR/GBP billing) ──────────────
# Get from: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Resend (Optional — enables email notifications) ───────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=

# ── LTI Integration (Optional) ────────────────────────────────────
LTI_CLIENT_ID=
LTI_DEPLOYMENT_ID=
